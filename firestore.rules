rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /exercises/{exerciseId}
    // Fields:
    //   - userId: string (required, immutable) - The UID of the user who performed the exercise.
    //   - userName: string (required) - The display name of the user.
    //   - type: string (required, max 50 chars) - The type of exercise.
    //   - duration: int (required, positive) - Duration in minutes.
    //   - timestamp: int (required) - Unix timestamp.
    //
    // Collection: /weights/{weightId}
    // Fields:
    //   - userId: string (required, immutable) - The UID of the user.
    //   - userName: string (required) - The display name of the user.
    //   - weight: number (required, positive) - Weight in kg.
    //   - timestamp: int (required) - Unix timestamp.
    //
    // Collection: /users/{userId}
    // Fields:
    //   - uid: string (required, immutable) - The unique identifier for the user.
    //   - displayName: string (required, max 50 chars) - The user's display name.
    //   - photoURL: string (optional, valid URL) - URL to the user's profile photo.
    //   - role: string (required, enum: ['user', 'admin']) - The user's role.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "wangluoqiwlq@gmail.com" && request.auth.token.email_verified == true)); // Default admin
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() > 0 &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string &&
        (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidExercise(data) {
      return hasRequiredFields(['userId', 'userName', 'type', 'duration', 'timestamp']) &&
             hasOnlyAllowedFields(['userId', 'userName', 'type', 'duration', 'timestamp', 'likes', 'comments']) &&
             data.userId is string &&
             data.userName is string && data.userName.size() <= 50 &&
             data.type is string && data.type.size() <= 50 &&
             data.duration is int && data.duration > 0 &&
             data.timestamp is int &&
             (!('likes' in data) || data.likes is list) &&
             (!('comments' in data) || data.comments is list);
    }

    function isValidWeight(data) {
      return hasRequiredFields(['userId', 'userName', 'weight', 'timestamp']) &&
             hasOnlyAllowedFields(['userId', 'userName', 'weight', 'timestamp']) &&
             data.userId is string &&
             data.userName is string && data.userName.size() <= 50 &&
             data.weight is number && data.weight > 0 &&
             data.timestamp is int;
    }

    function isOnlyUpdatingLikesOrComments() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'comments']);
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'displayName', 'role']) &&
             hasOnlyAllowedFields(['uid', 'displayName', 'photoURL', 'role']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() <= 50 &&
             data.role in ['user', 'admin'] &&
             (!('photoURL' in data) || isValidUrl(data.photoURL));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidExercise(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        (isDocOwner() && isValidExercise(request.resource.data) && request.resource.data.userId == resource.data.userId) ||
        (isOnlyUpdatingLikesOrComments() && isValidExercise(request.resource.data))
      );
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /weights/{weightId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidWeight(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isDocOwner() && isValidWeight(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
